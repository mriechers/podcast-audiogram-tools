# Audiogram Tools - Environment Variables

# ═══════════════════════════════════════════════════════════════
# Directory Configuration
# ═══════════════════════════════════════════════════════════════

# Directory to watch for new audio files
WATCH_DIR=./input

# Directory for rendered video output
OUTPUT_DIR=./output

# ═══════════════════════════════════════════════════════════════
# Render Configuration
# ═══════════════════════════════════════════════════════════════

# Maximum concurrent renders (for queue processing)
# Recommended: 1 for hour-long videos, 2-4 for short clips
MAX_CONCURRENT_RENDERS=1

# ═══════════════════════════════════════════════════════════════
# YouTube API Configuration
# ═══════════════════════════════════════════════════════════════
#
# To set up YouTube uploads:
# 1. Go to Google Cloud Console: https://console.cloud.google.com
# 2. Create a new project or select existing
# 3. Enable "YouTube Data API v3"
# 4. Go to Credentials > Create Credentials > OAuth 2.0 Client ID
# 5. Choose "Desktop app" as application type
# 6. Copy the Client ID and Client Secret below
#
# First run will open browser for authorization.
# Token is saved locally for future runs.

YOUTUBE_CLIENT_ID=your-client-id.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=your-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/oauth2callback
